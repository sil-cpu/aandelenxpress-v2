{
  "version": 1,
  "masterFlow": {
    "start": ["spoed", "contactEmail", "routeType"],
    "routes": [
      "working_only",
      "holding_plus_working",
      "holding_only",
      "geruisloze_inbreng"
    ],
    "modules": [
      "entity_base",
      "shareholder",
      "natural_person",
      "legal_person",
      "language",
      "sole_prop_or_vof",
      "address",
      "director",
      "accountant",
      "kvk_1",
      "kvk_2",
      "end_page"
    ]
  },
  "forms": {
    "vragenlijst": {
      "file": "public/vragenlijst.html",
      "routeType": "working_only",
      "enabledModules": [
        "entity_base",
        "shareholder",
        "natural_person",
        "legal_person",
        "language",
        "sole_prop_or_vof",
        "address",
        "director",
        "accountant",
        "kvk_1",
        "kvk_2",
        "end_page"
      ],
      "loops": {
        "holding": { "enabled": false, "min": 0, "max": 0 },
        "working": { "enabled": true, "min": 1, "max": 1 },
        "shareholder": { "enabled": true, "min": 1, "max": 4 },
        "director": { "enabled": true, "min": 1, "max": 4 },
        "ubo": { "enabled": true, "min": 1, "max": 4 }
      }
    },
    "vragenlijst_bv_holding": {
      "file": "public/vragenlijst-bv-holding.html",
      "routeType": "holding_plus_working",
      "enabledModules": [
        "entity_base",
        "shareholder",
        "natural_person",
        "legal_person",
        "language",
        "sole_prop_or_vof",
        "address",
        "director",
        "accountant",
        "kvk_1",
        "kvk_2",
        "end_page"
      ],
      "loops": {
        "holding": { "enabled": true, "min": 1, "max": 4 },
        "working": { "enabled": true, "min": 1, "max": 4 },
        "shareholder": { "enabled": true, "min": 1, "max": 4 },
        "director": { "enabled": true, "min": 1, "max": 4 },
        "ubo": { "enabled": true, "min": 1, "max": 4 }
      },
      "routeNotes": [
        "Ask working count after last holding round",
        "Only final route ends on END PAGE"
      ]
    },
    "vragenlijst_geruisloos": {
      "file": "public/vragenlijst-geruisloos.html",
      "routeType": "geruisloze_inbreng",
      "enabledModules": [
        "entity_base",
        "shareholder",
        "natural_person",
        "legal_person",
        "language",
        "sole_prop_or_vof",
        "address",
        "director",
        "accountant",
        "kvk_1",
        "kvk_2",
        "end_page"
      ],
      "loops": {
        "holding": { "enabled": true, "min": 0, "max": 4 },
        "working": { "enabled": true, "min": 0, "max": 4 },
        "shareholder": { "enabled": true, "min": 1, "max": 4 },
        "director": { "enabled": true, "min": 1, "max": 4 },
        "ubo": { "enabled": true, "min": 1, "max": 4 }
      },
      "extraRequirements": [
        "geruisloze supporting documents",
        "same NP/RP/language rules as other forms"
      ]
    }
  },
  "sharedConditionalRules": [
    {
      "id": "rule_show_which_shareholder",
      "when": "shareholderCount > 1 AND addressMode == 'same_as_shareholder'",
      "show": ["whichShareholder"],
      "hideOtherwise": true
    },
    {
      "id": "rule_kanaal_anders_toelichting",
      "when": "salesChannels.includes('anders')",
      "required": ["kanaalAndersOmschrijving"],
      "hideOtherwise": true
    },
    {
      "id": "rule_language_explanation",
      "when": "nlLevelC1Plus == false AND enLevelC1Plus == false",
      "required": ["motherLanguageAndC2Languages"]
    }
  ]
}
